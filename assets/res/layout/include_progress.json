{
    "type": "LinearLayout",
    "json_id": "progress_layout",
    "layout_width": "match_parent",
    "layout_height": "140dp",
    "orientation": "vertical",
    "layout_gravity": "center",
    "padding": "10dp",
    "background": "white",
    "children": [
        {
            "type": "ProgressBar",
            "json_id": "loader",
            "layout_width": "match_parent",
            "layout_height": "wrap_content",
            "gravity": "center",
            "indeterminateTint": "#2895F1",
            "progress": "25"
        },
        {
            "type": "TextView",
            "json_id": "no_internet",
            "visibility": "gone",
            "layout_width": "wrap_content",
            "layout_height": "wrap_content",
            "layout_marginTop": "7dp",
            "layout_marginBottom": "7dp",
            "gravity": "center",
            "layout_gravity": "center",
            "textSize": "14sp",
            "textColor": "black",
            "text": "@string/no_internet"
        },
        {                            
            "type": "TextView",
            "json_id": "retry",
            "visibility": "gone",
            "layout_width": "wrap_content",
            "layout_height": "wrap_content",
            "layout_margin": "10dp",
            "paddingStart": "18dp",
            "paddingEnd": "18dp",
            "paddingTop": "10dp",
            "paddingBottom": "10dp",
            "gravity": "center",
            "layout_gravity": "center",
            "background": "#1BDB68",
            "textColor": "white",
            "textSize": "18sp",
            "text": "@string/retry",
            "textAllCaps": "true"
        }
    ]
}